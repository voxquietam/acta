{
  "name": "acta-frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Acta frontend bundle — only used to compile the description editor (TipTap). Most of the app stays on CDN (HTMX, Alpine, Tailwind via Play CDN). See docs/decisions/0014-frontend-architecture.md for the rationale.",
  "scripts": {
    "build:js": "esbuild static_src/js/description_editor.js --bundle --format=iife --minify --target=es2020 --outfile=static/js/description_editor.bundle.js --log-level=info",
    "watch:js": "esbuild static_src/js/description_editor.js --bundle --format=iife --target=es2020 --outfile=static/js/description_editor.bundle.js --watch --log-level=info",
    "build:css": "tailwindcss -i static_src/css/main.css -o static/css/main.bundle.css --minify",
    "watch:css": "tailwindcss -i static_src/css/main.css -o static/css/main.bundle.css --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tailwindcss": "^3.4.17",
    "@tailwindcss/typography": "^0.5.15",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "lucide-static": "^0.469.0"
  },
  "dependencies": {
    "@tiptap/core": "^2.10.3",
    "@tiptap/extension-highlight": "^2.10.3",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/extension-task-item": "^2.10.3",
    "@tiptap/extension-task-list": "^2.10.3",
    "@tiptap/extension-typography": "^2.10.3",
    "@tiptap/extension-underline": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "tiptap-markdown": "^0.8.10"
  }
}
