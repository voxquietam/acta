# Copy to .env and fill in for local development.
# Never commit .env (already in .gitignore).
#
# For a PRODUCTION .env, see the "Deploy checklist (TL;DR)" in
# docs/operations.md — it lists every required + feature-toggle variable.
# The prod-only ones (commented out below) MUST be set on the server:
#   DJANGO_SETTINGS_MODULE=acta.settings.prod   # else it runs this dev config
#   DJANGO_MEDIA_ROOT=/var/lib/acta/media        # a PERSISTENT volume, or
#                                                # avatars + attachments are lost on rebuild

DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated full origins (scheme + host). Required in prod when
# reaching Django over HTTPS through a reverse proxy; left empty locally.
# Example: DJANGO_CSRF_TRUSTED_ORIGINS=https://actaspace.com,https://www.actaspace.com
DJANGO_CSRF_TRUSTED_ORIGINS=

POSTGRES_DB=acta
POSTGRES_USER=acta
POSTGRES_PASSWORD=acta

# Inside docker-compose: web → db:5432 over the internal network.
# If you run `python manage.py runserver` locally instead of inside the
# container, switch to POSTGRES_HOST=localhost and POSTGRES_PORT=5433.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Host-side port the Postgres container is exposed on (for psql / IDE).
# Defaults to 5433 to avoid colliding with another Postgres on 5432.
POSTGRES_HOST_PORT=5433

# Host-side port the Acta web container is exposed on.
# Defaults to 8001 to avoid colliding with another Django runserver on 8000.
WEB_HOST_PORT=8001

# Number of Uvicorn worker processes for the web container. Defaults to 1.
# Each worker is a full Django process (~250-400 MB) and opens its own
# Postgres connections (CONN_MAX_AGE persistent + SSE DB-polling), so scale
# this against available RAM and Postgres max_connections (default 100).
# There is no PgBouncer in the stack — add one before pushing this high.
# UVICORN_WORKERS=1

# Google OAuth — fill in after creating credentials at console.cloud.google.com.
# These are read by django-allauth at runtime via the admin Site/SocialApp.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Email — Gmail SMTP defaults. Generate an "app password" at
# myaccount.google.com/apppasswords (requires 2FA) and paste it as
# EMAIL_HOST_PASSWORD. Dev uses a console backend (see
# acta/settings/dev.py) so these only need to be set in prod.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=admin@actaspace.com
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=Acta <admin@actaspace.com>
# Public base URL used when no request context is available (e.g.
# management commands) — fallback for absolute invite URLs.
# ACTA_PUBLIC_BASE_URL=https://actaspace.com

# Telegram bot — DM notifications. All three optional; leave unset to keep
# the integration off (settings UI shows "not configured", nothing sends).
#   TELEGRAM_BOT_TOKEN      — from @BotFather (looks like 1234567890:AA...).
#   TELEGRAM_BOT_USERNAME   — the bot's @handle WITHOUT the @ (e.g. acta_tracker_bot).
#   TELEGRAM_WEBHOOK_SECRET — any random string you make up; guards the webhook.
#                             Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_SECRET=
